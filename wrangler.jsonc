{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tender-form",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "formzero",
			"database_id": "5181206e-78da-4299-a3e5-ddfbf8e8c607",
		}
	]
}